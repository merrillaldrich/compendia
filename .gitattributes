# Default: normalise line endings to LF in the repository
* text=auto

# Force LF for files that must stay Unix line endings
*.sh        text eol=lf
*.desktop   text eol=lf
.gitignore  text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
CMakeLists.txt text eol=lf
cmake/*.cmake  text eol=lf

# Binary files — no line ending conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.ico       binary
*.svg       binary
*.lib       binary
*.dll       binary
*.exe       binary
*.obj       binary
*.dat       binary
*.pdf       binary
